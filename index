// POKEAPI
// ═══════════════════════════════════════════
async function apiPoke(name){
  let n=name.toLowerCase().replace(/\s*\([mf]\)\s*$/i,'').replace(/\s*\([^)]*\)\s*/g,' ').trim().replace(/\s+/g,'-').replace(/[^a-z0-9\-]/g,'').replace(/-+/g,'-').replace(/^-|-$/g,'');
  n=n.replace(/-mega(-[xy])?$/,'').replace(/^mega-/,'').replace(/-alolan?$/,'').replace(/^alolan-/,'').replace(/-galarian?$/,'').replace(/^galarian-/,'').replace(/-hisuian?$/,'').replace(/^hisuian-/,'');
  const key='pk_'+n;if(C[key]) return C[key];
  try{const r=await fetch('https://pokeapi.co/api/v2/pokemon/'+n);if(!r.ok)throw 0;const d=await r.json();C[key]=d;return d;}catch(e){return null;}
}
async function apiMove(name){
  const key='mv_'+name;if(C[key]) return C[key];
  try{const r=await fetch('https://pokeapi.co/api/v2/move/'+name);if(!r.ok)return null;const d=await r.json();C[key]=d;return d;}catch(e){return null;}
}
function spriteHome(id){return `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/home/${id}.png`;}
function spriteDefault(id){return `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${id}.png`;}
function spriteBack(id){return `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/back/${id}.png`;}
// Sprite LOCAL del entrenador: archivo nombre_region.png que el usuario sube (ej: blue_kanto.png)
function trainerLocalSprite(name,region){
  return `./${name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]/g,'')}_${region}.png`;
}
// Asigna a un <img> el sprite del entrenador con cascada de fallbacks:
// 1) tu archivo local nombre_region.png  2) retrato oficial WikiDex  3) sprite del Pokémon líder
function setTrainerSprite(imgEl,opp,region,teamIdx){
  const chain=[trainerLocalSprite(opp.name,region)];
  const wiki=TRAINER_IMG[region+':'+opp.name];
  if(wiki) chain.push(wiki);
  if(opp.ts) chain.push(opp.ts);
  let i=0;
  const tryNext=()=>{
    if(i>=chain.length){
      imgEl.onerror=null;
      apiPoke(opp.teams[teamIdx||0][0].sp).then(d=>{imgEl.src=d?spriteDefault(d.id):spriteDefault(1);});
      return;
    }
    imgEl.src=chain[i++];
  };
  imgEl.onerror=tryNext;
  tryNext();
}

// ═══════════════════════════════════════════
// STAT CALCULATION
// ═══════════════════════════════════════════
function calcStats(p,baseData){
  const bs={};
  baseData.stats.forEach(s=>{const k=s.stat.name.replace('special-attack','spa').replace('special-defense','spd').replace('attack','atk').replace('defense','def').replace('speed','spe');bs[k]=s.base_stat;});
  const lv=p.level||100,nat=NATURES[p.nature]||{},iv=p.ivs||{hp:31,atk:31,def:31,spa:31,spd:31,spe:31},ev=p.evs||{},st={};
  st.hp=Math.floor(((2*(bs.hp||50)+(iv.hp||31)+Math.floor((ev.hp||0)/4))*lv/100)+lv+10);
  ['atk','def','spa','spd','spe'].forEach(s=>{
    let v=Math.floor((Math.floor(((2*(bs[s]||50)+(iv[s]!==undefined?iv[s]:31)+Math.floor((ev[s]||0)/4))*lv/100))+5)*(nat[s]||1));
    const it=ITEMS[p.item]||{};
    if(s==='def'&&it.defM) v=Math.floor(v*it.defM);
    if(s==='spd'&&it.spdM) v=Math.floor(v*it.spdM);
    if(s==='spe'&&it.speM) v=Math.floor(v*it.speM);
    st[s]=v;
  });
  return st;
}
function effStat(p,s){
  let v=p.stats[s];
  if(s==='atk'&&(p.ability==='huge-power'||p.ability==='pure-power')) v*=2;
  if(s==='atk'&&p.ability==='guts'&&p.status) v=Math.floor(v*1.5);
  if(s==='atk'&&p.status==='BRN'&&p.ability!=='guts') v=Math.floor(v*.5);
  if(s==='spe'&&p.status==='PAR') v=Math.floor(v*.25);
  if(s==='spd'&&(ITEMS[p.item]||{}).spdM) v=p.stats.spd; // already in base stats
  const b=(p.statBoosts&&p.statBoosts[s])||0;
  const tbl=[.25,.28,.33,.4,.5,.66,1,1.5,2,2.5,3,3.5,4];
  return Math.max(1,Math.floor(v*(tbl[b+6]||1)));
}
function typeEff(mtype,defTypes){
  if(!defTypes||!defTypes.length) return 1;
  let e=1;const ch=TYPECHART[mtype]||{};
  defTypes.forEach(t=>{e*=(ch[t]!==undefined?ch[t]:1);});
  return e;
}

// ═══════════════════════════════════════════
// PASTE PARSER
// ═══════════════════════════════════════════
function parsePaste(text){
  const blocks=text.trim().split(/\n[ \t]*\n/).filter(b=>b.trim());
  const team=[];
  for(const blk of blocks){
    const lines=blk.trim().split('\n').map(l=>l.trim()).filter(l=>l&&!l.startsWith('==='));
    if(!lines.length) continue;
    const p={species:'',nickname:'',item:'none',ability:'',level:100,
      evs:{hp:0,atk:0,def:0,spa:0,spd:0,spe:0},ivs:{hp:31,atk:31,def:31,spa:31,spd:31,spe:31},
      nature:'hardy',moves:[],currentHp:0,maxHp:0,status:null,statBoosts:{},usedSash:false,usedBerry:false,ppMap:{}};
    let l1=lines[0];const at=l1.indexOf('@');
    let nm=at>=0?l1.slice(0,at).trim():l1.trim();
    if(at>=0) p.item=l1.slice(at+1).trim().toLowerCase().replace(/\s+/g,'-');
    nm=nm.replace(/\s*\([MF]\)\s*$/,'').trim();
    const pm=nm.match(/^(.+?)\s*\(([^)]+)\)\s*$/);
    if(pm){p.nickname=pm[1].trim();p.species=pm[2].trim();}else p.species=nm.trim();
    p.displayName=p.nickname||cap(p.species.replace(/-/g,' '));
    for(let i=1;i<lines.length;i++){
      const ln=lines[i];
      if(ln.startsWith('Ability:')) p.ability=ln.slice(8).trim().toLowerCase().replace(/\s+/g,'-');
      else if(ln.startsWith('Level:')) p.level=parseInt(ln.slice(6))||100;
      else if(ln.startsWith('EVs:')){ln.slice(4).trim().split('/').forEach(pt=>{const m=pt.trim().match(/(\d+)\s+(.+)/);if(m){const k=statKey(m[2].trim());if(k)p.evs[k]=parseInt(m[1]);}});}
      else if(ln.startsWith('IVs:')){ln.slice(4).trim().split('/').forEach(pt=>{const m=pt.trim().match(/(\d+)\s+(.+)/);if(m){const k=statKey(m[2].trim());if(k)p.ivs[k]=parseInt(m[1]);}});}
      else if(/\bNature\b/i.test(ln)) p.nature=ln.replace(/\s*Nature\s*/i,'').trim().toLowerCase();
      else if(ln.startsWith('- ')){const mv=ln.slice(2).trim().toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9\-]/g,'').replace(/-+$/,'');if(mv&&p.moves.length<4)p.moves.push(mv);}
    }
    if(p.species&&p.moves.length>0) team.push(p);
  }
  return team.slice(0,6);
}
function statKey(s){const m={hp:'hp',atk:'atk',def:'def',spa:'spa','sp.atk':'spa','sp. atk':'spa','spatk':'spa',spd:'spd','sp.def':'spd','sp. def':'spd','spdef':'spd',spe:'spe',speed:'spe'};return m[s.toLowerCase().replace(/\s+/g,'')]||null;}

