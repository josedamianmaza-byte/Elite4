function newGame(){
  G={playerTeam:[],bp:0,items:{revive:0,maxpotion:0,fullrestore:0},progress:{},completed:{},playerSkin:'trainer1.png'};
  // marcar selección por defecto
  document.querySelectorAll('.char-card').forEach(c=>c.classList.remove('selected'));
  goTo('charselect');
}
function chooseSkin(skin,label){
  if(!G||!G.playerTeam) G={playerTeam:[],bp:0,items:{revive:0,maxpotion:0,fullrestore:0},progress:{},completed:{}};
  G.playerSkin=skin;
  document.querySelectorAll('.char-card').forEach(c=>c.classList.remove('selected'));
  const card=skin==='trainer2.png'?$('char-girl'):$('char-boy');
  if(card) card.classList.add('selected');
  goTo('team');
}
function playerSkinSprite(){
  return './'+((G&&G.playerSkin)||'trainer1.png');
}
async function continueGame(){
  if(loadGame()){
    goTo('team');
    if($('paste-input').value.trim()){
      await importTeam();
      if(G.playerTeam.length) goTo('hub');
    }
  } else {alert('No se encontró partida guardada.');}
}

