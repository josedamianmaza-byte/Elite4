// ═══════════════════════════════════════════
// AI — SMART MOVE SELECTION
// ═══════════════════════════════════════════
function aiMove(enemy,player){
  // Choice lock
  if(enemy.choiceMove&&(enemy.ppMap[enemy.choiceMove]||0)>0) return enemy.choiceMove;
  const avail=enemy.moves.filter(m=>(enemy.ppMap[m]||0)>0);
  if(!avail.length) return '_struggle';
  const it=ITEMS[enemy.item]||{};
  const noStatus=it.noStatus;

  let scored=avail.map(mv=>{
    const mvd=C['mv_'+mv];let score=25;
    if(!mvd){return{mv,score:25};}
    if(mvd.power){
      const mtype=mvd.type?.name||'normal';
      // Check ability immunity
      const immTypes=ABILITIES_IMM[player.ability]||[];
      if((ITEMS[player.item]||{}).immune?.includes(mtype)){score=-9000;}
      else if(immTypes.includes(mtype)){score=-9000;}
      else{
        const eff=typeEff(mtype,player.types);
        if(eff===0){score=-9000;}
        else{
          const cat=mvd.damage_class?.name;const isPhys=cat==='physical';
          const atkV=isPhys?effStat(enemy,'atk'):effStat(enemy,'spa');
          const defV=isPhys?effStat(player,'def'):effStat(player,'spd');
          const adaptStab=(enemy.ability==='adaptability'&&enemy.types?.includes(mtype))?2:1.5;
          const stab=enemy.types?.includes(mtype)?adaptStab:1;
          score=(mvd.power||0)*atkV/defV*stab*eff;
          if(eff>=2) score*=1.3;
          else if(eff<=0.5) score*=0.6;
        }
      }
    } else if(!noStatus){
      if(HEAL_MOVES.includes(mv)){const r=enemy.currentHp/enemy.maxHp;score=r<0.4?100:r<0.6?50:8;}
      else if(BOOST_MOVES[mv]){const r=enemy.currentHp/enemy.maxHp;score=r>0.6?75:r>0.4?35:8;}
      else if(!player.status) score=40;
      else score=8;
    } else score=-100;
    return {mv,score};
  });

  scored.sort((a,b)=>b.score-a.score);
  // 15% random factor
  if(Math.random()<0.15&&scored.length>1){
    const top=scored.slice(0,Math.min(3,scored.length));
    return top[Math.floor(Math.random()*top.length)].mv;
  }
  const chosen=scored[0].mv;
  if(it.choice) enemy.choiceMove=chosen;
  return chosen;
}

