// ═══════════════════════════════════════════
// MAIN PLAYER ACTION
// ═══════════════════════════════════════════
async function playerAction(mv){
  if(!B||!B.canAct) return;
  setEnabled(false);
  const player=G.playerTeam[B.playerIdx],enemy=B.enemyTeam[B.enemyIdx];
  player.ppMap[mv]=Math.max(0,(player.ppMap[mv]||1)-1);
  if((ITEMS[player.item]||{}).choice) player.choiceMove=mv;

  // Priority comparison
  const pPrio=PRIORITY_MOVES[mv]||0;
  const eMv=aiMove(enemy,player);
  if(eMv!=='_struggle') enemy.ppMap[eMv]=Math.max(0,(enemy.ppMap[eMv]||1)-1);
  const ePrio=PRIORITY_MOVES[eMv]||0;
  const pSpe=effStat(player,'spe'),eSpe=effStat(enemy,'spe');
  const playerFirst=pPrio>ePrio||(pPrio===ePrio&&pSpe>=eSpe);

  if(playerFirst){
    await executeMove(player,enemy,mv,true);
    if(enemy.currentHp<=0){await onEnemyFaint();return;}
    if(player.currentHp>0){await sleep(TURN_DELAY);await executeMove(enemy,player,eMv,false);}
  } else {
    await executeMove(enemy,player,eMv,false);
    if(player.currentHp<=0){await onPlayerFaint();return;}
    if(enemy.currentHp>0){await sleep(TURN_DELAY);await executeMove(player,enemy,mv,true);}
  }

  if(enemy.currentHp<=0){await onEnemyFaint();return;}
  if(player.currentHp<=0){await onPlayerFaint();return;}
  await sleep(HIT_DELAY);
  await endTurn();
  refreshBattleUI();
  if(player.currentHp<=0){await onPlayerFaint();return;}
  if(enemy.currentHp<=0){await onEnemyFaint();return;}
  await refreshMoves();setEnabled(true);
}

// ═══════════════════════════════════════════
// EXECUTE MOVE
// ═══════════════════════════════════════════
async function executeMove(att,def,moveName,isPlayer){
  if(!att||att.currentHp<=0) return;

  // Status blocks
  if(att.status==='SLP'){
    if(!att.sleepTurns) att.sleepTurns=1+Math.floor(Math.random()*3);
    att.sleepTurns--;
    if(att.sleepTurns<=0){att.status=null;att.sleepTurns=0;blogLine(`¡${att.displayName} se despertó!`,'heal');}
    else{blogLine(`${att.displayName} está dormido...`,'info');return;}
  }
  if(att.status==='FRZ'){
    if(Math.random()<.2){att.status=null;blogLine(`¡${att.displayName} se descongeló!`,'heal');}
    else{blogLine(`${att.displayName} está congelado...`,'info');return;}
  }
  if(att.status==='PAR'&&Math.random()<.25){blogLine(`¡${att.displayName} está paralizado!`,'info');return;}

  if(moveName==='_struggle'){
    const dmg=Math.max(1,Math.floor(att.maxHp/4));
    dealDmg(def,dmg,isPlayer);att.currentHp=Math.max(0,att.currentHp-dmg);
    blogLine(`${att.displayName} usa Forcejeo!`,'damage');refreshBattleUI();return;
  }

  const mvd=C['mv_'+moveName]||await apiMove(moveName);
  blogLine(`${att.displayName} usa ${fmtMv(moveName)}!`);
  await sleep(550);

  if(!mvd){
    const d=Math.max(1,Math.floor(att.stats.atk*.3));dealDmg(def,d,!isPlayer);return;
  }

  // Accuracy
  if(mvd.accuracy&&Math.random()*100>mvd.accuracy){
    blogLine('¡El ataque falló!','info');showDmgFloat(0,isPlayer,'miss');return;
  }

  const mtype=mvd.type?.name||'normal';
  const cat=mvd.damage_class?.name;
  const power=mvd.power;

  // Immunity checks
  const immTypes=ABILITIES_IMM[def.ability]||[];
  const balloonImmune=(def.item==='air-balloon')&&mtype==='ground';
  if(balloonImmune){
    blogLine(`¡El Globo Aire protege a ${def.displayName}!`,'info');return;
  }
  if(immTypes.includes(mtype)){
    // Absorption abilities
    if((def.ability==='water-absorb'||def.ability==='storm-drain')&&mtype==='water'){
      const heal=Math.floor(def.maxHp*.25);def.currentHp=Math.min(def.maxHp,def.currentHp+heal);
      blogLine(`¡${def.displayName} absorbió el agua!`,'heal');showDmgFloat(heal,isPlayer,'heal');refreshBattleUI();return;
    }
    if((def.ability==='volt-absorb'||def.ability==='lightning-rod')&&mtype==='electric'){
      const heal=Math.floor(def.maxHp*.25);def.currentHp=Math.min(def.maxHp,def.currentHp+heal);
      blogLine(`¡${def.displayName} absorbió la electricidad!`,'heal');showDmgFloat(heal,isPlayer,'heal');refreshBattleUI();return;
    }
    if(def.ability==='flash-fire'&&mtype==='fire'){
      def.flashFireActive=true;blogLine(`¡Flash Fire de ${def.displayName} se activó!`,'super');return;
    }
    if(def.ability==='sap-sipper'&&mtype==='grass'){
      def.statBoosts.atk=Math.min(6,(def.statBoosts.atk||0)+1);
      blogLine(`¡${def.displayName} absorbió el ataque!`,'super');return;
    }
    blogLine(`¡No afecta a ${def.displayName}!`,'resist');return;
  }

  // Status moves
  if(!power||cat==='status'){
    await handleStatusMove(att,def,mvd,moveName);
    // Self stat drops for moves like Shell Smash
    if(BOOST_MOVES[moveName]?.def){
      const b=BOOST_MOVES[moveName];
      Object.entries(b).forEach(([s,v])=>{if(typeof v==='number'&&s!=='_transfer') att.statBoosts[s]=Math.max(-6,Math.min(6,(att.statBoosts[s]||0)+v));});
    }
    return;
  }

  // Damage move
  const isPhys=cat==='physical';
  const eff=typeEff(mtype,def.types);
  if(eff===0){blogLine(`¡No afecta a ${def.displayName}!`,'resist');showDmgFloat(0,isPlayer,'miss');return;}

  let atkV=isPhys?effStat(att,'atk'):effStat(att,'spa');
  let defV=isPhys?effStat(def,'def'):effStat(def,'spd');

  // Flash Fire boost
  if(mtype==='fire'&&att.flashFireActive) atkV=Math.floor(atkV*1.5);
  // Thick Fat
  let effM=1;
  if(def.ability==='thick-fat'&&(mtype==='fire'||mtype==='ice')) effM=.5;
  // Multiscale
  if((def.ability==='multiscale'||def.ability==='shadow-shield')&&def.currentHp>=def.maxHp) effM*=.5;
  // Solid Rock / Filter
  if((def.ability==='solid-rock'||def.ability==='filter')&&eff>=2) effM*=.75;

  // STAB
  const adaptability=att.ability==='adaptability';
  const stab=att.types?.includes(mtype)?(adaptability?2:1.5):1;

  // Weather
  let wm=1;
  if(B.weather==='sun'){if(mtype==='fire')wm=1.5;if(mtype==='water')wm=.5;}
  if(B.weather==='rain'){if(mtype==='water')wm=1.5;if(mtype==='fire')wm=.5;}

  const crit=Math.random()<.0625;

  // Item multipliers
  const it=ITEMS[att.item]||{};
  let iM=it.dmgM||1;
  if(isPhys&&it.atkM) iM*=it.atkM;
  if(!isPhys&&it.spaM) iM*=it.spaM;
  if(it.typeM===mtype) iM*=1.2;
  if(att.ability==='expert-belt'&&eff>1) iM*=1.2;
  if(att.item==='expert-belt'&&eff>1) iM*=1.2;
  if(att.ability==='technician'&&(power||0)<=60) iM*=1.5;
  if(att.ability==='tinted-lens'&&eff<1) iM*=2;
  const sheerForce=att.ability==='sheer-force';
  if(sheerForce) iM*=1.3;

  // Multi-hit
  let hits=1;
  const minH=mvd.meta?.min_hits,maxH=mvd.meta?.max_hits;
  if(maxH&&maxH>1){
    if(att.ability==='skill-link'){hits=maxH;}
    else{const r=Math.random();hits=maxH===5?(r<.375?2:r<.75?3:r<.875?4:5):minH+Math.floor(Math.random()*(maxH-minH+1));}
  }

  let totalDmg=0;let actualHits=0;
  for(let h=0;h<hits;h++){
    const dmgRaw=Math.floor(((2*att.level/5+2)*(power||40)*atkV/defV/50+2)*stab*eff*wm*iM*effM*(crit?1.5:1)*(0.85+Math.random()*.15));
    let dmg=Math.max(1,dmgRaw);
    if(def.item==='focus-sash'&&!def.usedSash&&def.currentHp===def.maxHp&&dmg>=def.currentHp){
      dmg=def.currentHp-1;def.usedSash=true;blogLine(`¡Focus Sash de ${def.displayName} aguantó!`,'info');
    }
    dealDmg(def,dmg,isPlayer);
    totalDmg+=dmg;actualHits++;
    showDmgFloat(dmg,isPlayer,eff>=2?'super':'dmg');
    if(def.currentHp<=0) break;
    if(hits>1) await sleep(200);
  }
  await sleep(HIT_DELAY);
  if(hits>1) blogLine(`¡${actualHits} golpes!`,'info');
  if(eff>=2) blogLine('🌟 ¡Es muy eficaz!','super');
  else if(eff<1&&eff>0) blogLine('👊 No es muy eficaz...','resist');
  if(crit) blogLine('🎯 ¡Golpe crítico!','super');

  // Air Balloon pop
  if(def.item==='air-balloon'&&def.currentHp>0){def.item='none';blogLine(`¡El Globo Aire de ${def.displayName} explotó!`,'info');}

  // Life Orb recoil
  if(att.item==='life-orb'&&att.ability!=='magic-guard'){const lo=Math.floor(att.maxHp*.1);att.currentHp=Math.max(0,att.currentHp-lo);showDmgFloat(lo,!isPlayer,'dmg');blogLine(`${att.displayName} sufre el retroceso del Life Orb.`,'damage');}

  // Rocky Helmet / Rough Skin / Iron Barbs (contact moves)
  if(isPhys&&def.currentHp>0){
    if(def.item==='rocky-helmet'){att.currentHp=Math.max(0,att.currentHp-Math.floor(att.maxHp*.167));blogLine(`${att.displayName} sufre daño del Rocky Helmet!`,'damage');}
    if(def.ability==='rough-skin'||def.ability==='iron-barbs'){att.currentHp=Math.max(0,att.currentHp-Math.floor(att.maxHp*.125));blogLine(`${att.displayName} sufre daño de ${def.ability==='rough-skin'?'Piel Tosca':'Pinchos'}!`,'damage');}
  }

  // Move recoil
  const selfDrop=SELF_DROP_MOVES[moveName]||{};
  if(selfDrop.hp_recoil&&att.currentHp>0&&att.ability!=='rock-head'){
    const rc=Math.floor(totalDmg*selfDrop.hp_recoil);att.currentHp=Math.max(0,att.currentHp-rc);blogLine(`${att.displayName} sufre daño por retroceso!`,'damage');
  }

  // Self stat drops (Close Combat etc)
  const drops={};
  if(selfDrop.def) drops.def=selfDrop.def;
  if(selfDrop.spd) drops.spd=selfDrop.spd;
  if(selfDrop.atk) drops.atk=selfDrop.atk;
  if(selfDrop.spa) drops.spa=selfDrop.spa;
  if(selfDrop.spe) drops.spe=selfDrop.spe;
  if(Object.keys(drops).length){
    Object.entries(drops).forEach(([s,v])=>{att.statBoosts[s]=Math.max(-6,(att.statBoosts[s]||0)+v);});
    if(att.currentHp>0) blogLine(`Los stats de ${att.displayName} bajaron!`,'info');
  }

  // White Herb: restore negative boosts
  if(att.item==='white-herb'&&!att.usedBerry&&att.currentHp>0){
    let hasNeg=false;Object.values(att.statBoosts).forEach(v=>{if(v<0)hasNeg=true;});
    if(hasNeg){Object.keys(att.statBoosts).forEach(k=>{if(att.statBoosts[k]<0)att.statBoosts[k]=0;});att.usedBerry=true;blogLine(`¡Hierba Blanca de ${att.displayName} restauró sus stats!`,'heal');}
  }

  // Secondary status (unless Sheer Force)
  if(!sheerForce&&def.currentHp>0){
    const ailment=mvd.meta?.ailment?.name;
    if(ailment&&ailment!=='none'&&!def.status){
      const chance=mvd.meta?.ailment_chance||0;
      if(chance>0&&Math.random()*100<(att.ability==='serene-grace'?chance*2:chance)) applyStatus(def,ailment);
    }
    if(mvd.meta?.flinch_chance>0&&Math.random()*100<(att.ability==='serene-grace'?mvd.meta.flinch_chance*2:mvd.meta.flinch_chance)) def.flinched=true;
  }

  checkSitrus(def);checkSitrus(att);
  refreshBattleUI();
}

// ═══════════════════════════════════════════
// STATUS MOVES HANDLER
// ═══════════════════════════════════════════
async function handleStatusMove(att,def,mvd,mn){
  if(WEATHER_MOVES[mn]){const w=WEATHER_MOVES[mn];B.weather=w.w;B.weatherTurns=8;blogLine(w.msg,'info');return;}
  if(mn==='rest'){
    if(att.ability==='magic-guard'||(att.currentHp===att.maxHp&&!att.status)){blogLine('¡No tuvo efecto!','info');return;}
    att.currentHp=att.maxHp;att.status='SLP';att.sleepTurns=2;
    blogLine(`${att.displayName} usó Descanso y se durmió.`,'heal');refreshBattleUI();return;
  }
  if(HEAL_MOVES.includes(mn)){
    let healAmt=Math.floor(att.maxHp*.5);
    if(B.weather==='sun'&&(mn==='moonlight'||mn==='morning-sun'||mn==='synthesis')) healAmt=Math.floor(att.maxHp*.667);
    att.currentHp=Math.min(att.maxHp,att.currentHp+healAmt);
    showDmgFloat(healAmt,att===G.playerTeam[B.playerIdx]?false:true,'heal');
    blogLine(`${att.displayName} recuperó HP!`,'heal');refreshBattleUI();return;
  }
  if(BOOST_MOVES[mn]){
    const b=BOOST_MOVES[mn];
    if(b._transfer){blogLine(`${att.displayName} pasó sus stats!`,'info');return;}
    Object.entries(b).forEach(([s,v])=>{if(s!=='_transfer') att.statBoosts[s]=Math.max(-6,Math.min(6,(att.statBoosts[s]||0)+v));});
    if(b.atk>0||b.spa>0||b.spe>0) blogLine(`¡${att.displayName} subió sus stats de ataque!`,'super');
    else if(b.def>0||b.spd>0) blogLine(`¡${att.displayName} subió sus stats de defensa!`,'super');
    else blogLine(`¡${att.displayName} cambió sus stats!`,'super');
    return;
  }
  if(mvd?.meta?.ailment?.name&&mvd.meta.ailment.name!=='none'){
    if(!def.status) applyStatus(def,mvd.meta.ailment.name);
    else blogLine('¡No tuvo efecto!','info');return;
  }
  blogLine(`${att.displayName} usa ${fmtMv(mn)}...`,'info');
}

function applyStatus(poke,ailment){
  const m={burn:'BRN',paralysis:'PAR',poison:'PSN','bad-poison':'PSN',sleep:'SLP',freeze:'FRZ'};
  const s=m[ailment];if(!s) return;
  if(poke.status) return;
  // Immunity: fire types can't be burned, electric can't be paralyzed, etc.
  if(s==='BRN'&&poke.types?.includes('fire')) return;
  if(s==='PAR'&&poke.types?.includes('electric')) return;
  if(s==='PSN'&&(poke.types?.includes('poison')||poke.types?.includes('steel'))) return;
  if(s==='FRZ'&&poke.types?.includes('ice')) return;
  poke.status=s;
  if(s==='SLP') poke.sleepTurns=1+Math.floor(Math.random()*3);
  const msgs={BRN:'fue quemado',PAR:'fue paralizado',PSN:'fue envenenado',SLP:'se durmió',FRZ:'fue congelado'};
  blogLine(`¡${poke.displayName} ${msgs[s]}!`,'damage');
  if(poke.item==='lum-berry'&&!poke.usedBerry){poke.status=null;poke.usedBerry=true;blogLine(`¡${poke.displayName} curó su estado con Baya Lum!`,'heal');}
  if(s==='SLP') poke.sleepTurns=0;
  refreshBattleUI();
}
function checkSitrus(poke){
  const it=ITEMS[poke.item]||{};
  if(it.sitrus&&!poke.usedBerry&&poke.currentHp<=poke.maxHp*.5&&poke.currentHp>0){
    const h=Math.floor(poke.maxHp*it.sitrus);poke.currentHp=Math.min(poke.maxHp,poke.currentHp+h);
    poke.usedBerry=true;blogLine(`${poke.displayName} recuperó HP con Baya Sitrus!`,'heal');
  }
}
function dealDmg(poke,dmg,isEnemy){
  poke.currentHp=Math.max(0,poke.currentHp-dmg);
  shake(isEnemy?'e-sprite':'p-sprite');
  refreshBattleUI();
}
function shake(id){const el=$(id);el.classList.remove('sp-shake');void el.offsetWidth;el.classList.add('sp-shake');setTimeout(()=>el.classList.remove('sp-shake'),400);}

// ═══════════════════════════════════════════
// END OF TURN
// ═══════════════════════════════════════════
async function endTurn(){
  const p=G.playerTeam[B.playerIdx],e=B.enemyTeam[B.enemyIdx];
  [p,e].forEach(pk=>{
    if(!pk||pk.currentHp<=0) return;
    const ab=pk.ability;const it=ITEMS[pk.item]||{};
    // Burn / Poison
    if(pk.status==='BRN'&&ab!=='magic-guard'){pk.currentHp=Math.max(0,pk.currentHp-Math.floor(pk.maxHp*.0625));blogLine(`${pk.displayName} sufre daño por quemadura!`,'damage');}
    if(pk.status==='PSN'){
      if(ab==='poison-heal'){pk.currentHp=Math.min(pk.maxHp,pk.currentHp+Math.floor(pk.maxHp*.125));blogLine(`${pk.displayName} se cura con veneno!`,'heal');}
      else if(ab!=='magic-guard'){pk.currentHp=Math.max(0,pk.currentHp-Math.floor(pk.maxHp*.0625));blogLine(`${pk.displayName} sufre daño por veneno!`,'damage');}
    }
    // Leftovers / Black Sludge
    if(it.eot&&ab!=='magic-guard') pk.currentHp=Math.min(pk.maxHp,pk.currentHp+Math.floor(pk.maxHp*it.eot));
    // Flame/Toxic Orb
    if(it.flameBurn&&!pk.status) applyStatus(pk,'burn');
    if(it.toxicPoison&&!pk.status) applyStatus(pk,'poison');
    // Speed Boost
    if(ab==='speed-boost') pk.statBoosts.spe=Math.min(6,(pk.statBoosts.spe||0)+1);
    // Moxie tracking reset
    pk.flinched=false;
  });
  // Weather
  if(B.weather){
    B.weatherTurns--;
    if(B.weatherTurns<=0){blogLine('El tiempo volvió a la normalidad.','info');B.weather=null;}
    else if(B.weather==='sand'){
      [p,e].forEach(pk=>{if(!pk||pk.currentHp<=0) return;if(!['rock','steel','ground'].some(t=>pk.types?.includes(t))&&pk.ability!=='magic-guard'&&pk.ability!=='sand-veil'&&pk.ability!=='sand-rush'){pk.currentHp=Math.max(0,pk.currentHp-Math.floor(pk.maxHp*.0625));blogLine(`${pk.displayName} es golpeado por la arena!`,'damage');}});
    } else if(B.weather==='hail'){
      [p,e].forEach(pk=>{if(!pk||pk.currentHp<=0) return;if(!pk.types?.includes('ice')&&pk.ability!=='magic-guard'&&pk.ability!=='ice-body'&&pk.ability!=='snow-cloak'){pk.currentHp=Math.max(0,pk.currentHp-Math.floor(pk.maxHp*.0625));blogLine(`${pk.displayName} es golpeado por el granizo!`,'damage');}});
    }
  }
  B.turn++;
}

// ═══════════════════════════════════════════
// FAINT HANDLERS
// ═══════════════════════════════════════════
async function onEnemyFaint(){
  const e=B.enemyTeam[B.enemyIdx];
  blogLine(`¡${e.displayName} fue debilitado!`,'super');
  const es=$('e-sprite');es.classList.add('sp-faint');
  await sleep(FAINT_DELAY);es.classList.remove('sp-faint');es.style.display='none';

  // Moxie / Beast Boost
  const poke=G.playerTeam[B.playerIdx];
  if(poke.ability==='moxie'&&poke.currentHp>0){
    poke.statBoosts.atk=Math.min(6,(poke.statBoosts.atk||0)+1);
    blogLine(`¡Moxie de ${poke.displayName} subió su Ataque!`,'super');
  }

  B.enemyIdx++;
  if(B.enemyIdx>=B.enemyTeam.length){await onBattleWin();return;}
  const next=B.enemyTeam[B.enemyIdx];
  blogLine(`¡${B.opp.name} envía a ${next.displayName}!`,'info');
  await sleep(700);
  await checkEntry(next,G.playerTeam[B.playerIdx],true);
  await refreshSprites();refreshBattleUI();renderPartyRow();await refreshMoves();setEnabled(true);
}

async function onPlayerFaint(){
  const p=G.playerTeam[B.playerIdx];
  blogLine(`¡${p.displayName} fue debilitado!`,'damage');
  const ps=$('p-sprite');ps.classList.add('sp-faint');
  await sleep(FAINT_DELAY);ps.classList.remove('sp-faint');ps.style.display='none';
  const alive=G.playerTeam.filter((_,i)=>i!==B.playerIdx&&G.playerTeam[i].currentHp>0);
  if(!alive.length){await onBattleLoss();return;}
  blogLine('¡Elige tu siguiente Pokémon!','info');
  B.switchForced=true;renderPartyRow();openSwitch();
}

async function onBattleWin(){
  const isChamp=B.memberIdx===REGIONS[B.region].members.length-1;
  const bp=isChamp?50:20;
  G.bp+=bp;
  G.progress[B.region]=(G.progress[B.region]||0)+1;
  if(isChamp) G.completed[B.region]=true;
  saveGame();
  modal(isChamp?'⭐ ¡CAMPEÓN!':'¡Victoria!',
    (isChamp?`¡Has conquistado el Alto Mando de ${REGIONS[B.region].name}!<br><br>`:
    `¡Has derrotado a ${B.opp.name}!<br><br>`)+'<b style="color:var(--gold)">+'+bp+' BP</b> obtenidos',
    [{text:'Continuar →',fn:()=>goTo('hub')}]);
}

async function onBattleLoss(){
  G.playerTeam.forEach(p=>{if(p.currentHp<=0)p.currentHp=Math.floor(p.maxHp*.1);});
  modal('💀 Derrota','Todos tus Pokémon fueron debilitados.<br>Usa items en la tienda antes de reintentar.',
    [{text:'Volver al Hub',fn:()=>goTo('hub')}]);
}

// ═══════════════════════════════════════════
// SWITCH & ITEMS
// ═══════════════════════════════════════════
function openSwitch(){
  $('moves-ui').style.display='none';$('switch-ui').style.display='block';
  $('btn-cancel-switch').style.display=B.switchForced?'none':'inline-block';
  const g=$('party-grid');g.innerHTML='';
  G.playerTeam.forEach((p,i)=>{
    const btn=document.createElement('button');btn.className='party-btn';
    const pct=Math.max(0,(p.currentHp/p.maxHp)*100);
    const hc=pct>50?'var(--green)':pct>20?'var(--yellow)':'var(--red2)';
    btn.innerHTML=`<img src="${spriteDefault(p.id||1)}" alt="${p.displayName}" onerror="this.src='${spriteDefault(1)}'">
      <div>${p.displayName}</div>
      <div style="color:${hc};font-size:9px;">${p.currentHp}/${p.maxHp}</div>`;
    btn.disabled=p.currentHp<=0||i===B.playerIdx;
    btn.onclick=()=>doSwitch(i);
    g.appendChild(btn);
  });
}
function closeSwitch(){
  if(B&&B.switchForced) return;
  $('switch-ui').style.display='none';$('moves-ui').style.display='block';
}
async function doSwitch(idx){
  const wasForced=B.switchForced;
  // Natural cure on switch out
  const old=G.playerTeam[B.playerIdx];
  if(old.ability==='natural-cure') old.status=null;
  if(old.ability==='regenerator'&&old.currentHp>0){old.currentHp=Math.min(old.maxHp,old.currentHp+Math.floor(old.maxHp/3));blogLine(`${old.displayName} recuperó HP!`,'heal');}
  B.playerIdx=idx;B.switchForced=false;
  G.playerTeam[idx].statBoosts={};G.playerTeam[idx].choiceMove=null;
  $('switch-ui').style.display='none';$('moves-ui').style.display='block';
  blogLine(`¡Adelante, ${G.playerTeam[idx].displayName}!`,'info');
  await checkEntry(G.playerTeam[idx],B.enemyTeam[B.enemyIdx],false);
  await refreshSprites();refreshBattleUI();renderPartyRow();await refreshMoves();
  if(!wasForced){
    const eMv=aiMove(B.enemyTeam[B.enemyIdx],G.playerTeam[idx]);
    if(eMv!=='_struggle') B.enemyTeam[B.enemyIdx].ppMap[eMv]=Math.max(0,(B.enemyTeam[B.enemyIdx].ppMap[eMv]||1)-1);
    await executeMove(B.enemyTeam[B.enemyIdx],G.playerTeam[B.playerIdx],eMv,false);
    if(G.playerTeam[B.playerIdx].currentHp<=0){await onPlayerFaint();return;}
    await endTurn();refreshBattleUI();
  }
  setEnabled(true);
}

function confirmFlee(){modal('Rendirse','¿Seguro que quieres abandonar el combate?',[{text:'Sí',cls:'btn-secondary',fn:()=>goTo('hub')},{text:'No',fn:()=>{}}]);}

function openItems(){
  if(!B) return;
  const p=G.playerTeam[B.playerIdx];
  const fainted=G.playerTeam.filter(pk=>pk.currentHp<=0);
  modal('Mochila',
    `<div style="text-align:left;line-height:2.2;font-size:12px;">
      🔵 Revivir ×${G.items.revive} — Revive al primer Pokémon caído<br>
      💊 Max Poción ×${G.items.maxpotion} — HP completo a ${p.displayName}<br>
      ✨ Full Restore ×${G.items.fullrestore} — HP + estado a ${p.displayName}
    </div>`,
    [
      {text:`Revivir (${G.items.revive})`,cls:'btn-secondary',fn:async()=>{
        if(!G.items.revive||!fainted.length){modal('Sin objetivo','',[{text:'OK',fn:()=>{}}]);return;}
        G.items.revive--;fainted[0].currentHp=Math.floor(fainted[0].maxHp*.5);
        blogLine(`¡${fainted[0].displayName} fue revivido!`,'heal');refreshBattleUI();renderPartyRow();
      }},
      {text:`Max Poción (${G.items.maxpotion})`,cls:'btn-secondary',fn:async()=>{
        if(!G.items.maxpotion){modal('Sin items','',[{text:'OK',fn:()=>{}}]);return;}
        G.items.maxpotion--;p.currentHp=p.maxHp;blogLine(`¡${p.displayName} recuperó HP!`,'heal');refreshBattleUI();
        const eMv=aiMove(B.enemyTeam[B.enemyIdx],p);if(eMv!=='_struggle') B.enemyTeam[B.enemyIdx].ppMap[eMv]=Math.max(0,(B.enemyTeam[B.enemyIdx].ppMap[eMv]||1)-1);
        await executeMove(B.enemyTeam[B.enemyIdx],p,eMv,false);
        if(p.currentHp<=0) await onPlayerFaint();
        else{await endTurn();refreshBattleUI();renderPartyRow();setEnabled(true);}
      }},
      {text:`Full Restore (${G.items.fullrestore})`,cls:'btn-secondary',fn:async()=>{
        if(!G.items.fullrestore){modal('Sin items','',[{text:'OK',fn:()=>{}}]);return;}
        G.items.fullrestore--;p.currentHp=p.maxHp;p.status=null;blogLine(`¡${p.displayName} se recuperó!`,'heal');refreshBattleUI();
        const eMv=aiMove(B.enemyTeam[B.enemyIdx],p);if(eMv!=='_struggle') B.enemyTeam[B.enemyIdx].ppMap[eMv]=Math.max(0,(B.enemyTeam[B.enemyIdx].ppMap[eMv]||1)-1);
        await executeMove(B.enemyTeam[B.enemyIdx],p,eMv,false);
        if(p.currentHp<=0) await onPlayerFaint();
        else{await endTurn();refreshBattleUI();renderPartyRow();setEnabled(true);}
      }},
      {text:'Cancelar',cls:'btn-secondary',fn:()=>{}}
    ]);
}

