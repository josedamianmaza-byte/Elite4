<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pokémon Elite Challenge</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Exo+2:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --red:#e6001a;--dark-red:#990011;--gold:#ffd700;--gold2:#ffe566;
  --bg:#06091a;--bg2:#090e24;--panel:rgba(10,16,44,0.97);--card:rgba(16,24,60,0.92);
  --border:rgba(50,70,160,0.45);--border2:rgba(90,120,240,0.7);
  --text:#c8d8ff;--muted:#5e6f9a;--dim:#8896bc;
  --green:#22c55e;--yellow:#eab308;--orange:#f97316;--red2:#ef4444;
  --px:'Press Start 2P',monospace;--font:'Exo 2','Segoe UI',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:var(--font);min-height:100vh;display:flex;flex-direction:column;align-items:center;overflow-x:hidden;}
::-webkit-scrollbar{width:4px;}::-webkit-scrollbar-track{background:var(--bg);}::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

/* SCREENS */
.screen{display:none;width:100%;max-width:960px;padding:16px;}
.screen.active{display:flex;flex-direction:column;animation:screenIn .3s ease;}
@keyframes screenIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

/* TITLE SCREEN */
#screen-title{align-items:center;justify-content:center;min-height:100vh;gap:18px;text-align:center;position:relative;overflow:hidden;padding:0;}
canvas#stars{position:fixed;top:0;left:0;pointer-events:none;z-index:0;}
.title-content{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:16px;}
.title-eyebrow{font-family:var(--px);font-size:8px;color:var(--muted);letter-spacing:4px;}
.title-main{font-family:var(--px);font-size:clamp(20px,5vw,36px);background:linear-gradient(135deg,#ffd700 0%,#fff5a0 50%,#ffb700 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1.3;text-shadow:none;filter:drop-shadow(0 0 20px rgba(255,215,0,.35));}
.title-sub{font-size:13px;color:var(--muted);max-width:380px;line-height:1.6;}
.title-dino{width:120px;height:120px;image-rendering:pixelated;animation:bob 1.4s ease-in-out infinite alternate;filter:drop-shadow(0 0 18px rgba(255,215,0,.3));}
@keyframes bob{from{transform:translateY(0) rotate(-1deg);}to{transform:translateY(-12px) rotate(1deg);}}
.title-regions{font-size:9px;color:var(--muted);letter-spacing:2px;}
.title-btns{display:flex;flex-direction:column;gap:10px;align-items:center;}

/* BUTTONS */
.btn-primary{background:linear-gradient(135deg,#cc0011 0%,#990011 100%);color:#fff;border:1px solid rgba(255,100,100,.3);padding:13px 36px;font-family:var(--px);font-size:11px;cursor:pointer;letter-spacing:2px;text-transform:uppercase;transition:all .15s;box-shadow:0 4px 16px rgba(220,0,20,.3);}
.btn-primary:hover{filter:brightness(1.15);transform:scale(1.02);box-shadow:0 6px 24px rgba(220,0,20,.5);}
.btn-primary:disabled{opacity:.4;cursor:not-allowed;transform:none;}
.btn-gold{background:linear-gradient(135deg,#8a7000 0%,#c0a000 100%);color:var(--gold2);border:1px solid rgba(255,215,0,.3);padding:12px 28px;font-family:var(--px);font-size:10px;cursor:pointer;letter-spacing:1px;transition:all .15s;}
.btn-gold:hover{filter:brightness(1.2);transform:scale(1.02);}
.btn-secondary{background:var(--card);border:1px solid var(--border);color:var(--text);font-family:var(--font);font-size:12px;padding:8px 16px;cursor:pointer;letter-spacing:.5px;transition:all .1s;}
.btn-secondary:hover:not(:disabled){border-color:var(--gold);color:var(--gold);}
.btn-secondary:disabled{opacity:.3;cursor:not-allowed;}

/* PANELS */
.panel{background:var(--panel);border:1px solid var(--border);padding:18px;margin-bottom:0;}
.panel-title{font-family:var(--px);font-size:8px;color:var(--gold);letter-spacing:2px;margin-bottom:14px;border-bottom:1px solid var(--border);padding-bottom:10px;display:flex;align-items:center;gap:8px;}

/* TEAM BUILDER */
#screen-team{gap:14px;padding-top:20px;}
.team-import-wrap{position:relative;}
textarea{width:100%;background:rgba(0,0,0,.6);border:1px solid var(--border);color:var(--text);font-family:'Courier New',monospace;font-size:11px;padding:12px;resize:vertical;min-height:190px;line-height:1.7;}
textarea:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 1px rgba(255,215,0,.2);}
.team-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-top:10px;}
.poke-card{background:var(--card);border:1px solid var(--border);padding:8px;text-align:center;min-height:118px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;transition:border-color .2s;}
.poke-card:hover{border-color:var(--border2);}
.poke-card img{width:72px;height:72px;image-rendering:pixelated;object-fit:contain;}
.poke-name{font-size:9px;color:var(--gold);text-transform:uppercase;word-break:break-all;line-height:1.3;font-weight:700;}
.poke-level{font-size:8px;color:var(--muted);}
.type-badge{display:inline-block;font-size:7px;padding:2px 5px;border-radius:2px;text-transform:uppercase;font-weight:bold;color:#fff;margin:1px;}
.msg-err{color:#ff5566;font-size:11px;padding:6px 0;}
.msg-ok{color:var(--green);font-size:11px;padding:6px 0;}

/* HUB */
#screen-hub{gap:14px;}
.hub-header{display:grid;grid-template-columns:1fr auto auto;gap:12px;align-items:center;padding:14px 18px;background:var(--panel);border:1px solid var(--border);}
.bp-block .bp-label{font-size:9px;color:var(--muted);font-family:var(--px);}
.bp-block .bp-val{font-size:26px;color:var(--gold);font-weight:800;}
.hub-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
@media(max-width:640px){.hub-grid{grid-template-columns:1fr;}.team-grid{grid-template-columns:repeat(3,1fr);}}
.region-card{background:var(--panel);border:1px solid var(--border);padding:16px 18px;cursor:pointer;transition:all .18s;position:relative;overflow:hidden;}
.region-card:not(.locked):hover{border-color:var(--border2);transform:translateY(-2px);box-shadow:0 8px 28px rgba(60,100,255,.12);}
.region-card.locked{opacity:.45;cursor:not-allowed;}
.region-card.done{border-color:rgba(34,197,94,.45);}
.region-card .rc-bar{position:absolute;top:0;left:0;right:0;height:3px;}
.rc-kanto .rc-bar{background:linear-gradient(90deg,#cc0000,#ff6666);}
.rc-johto .rc-bar{background:linear-gradient(90deg,#0044cc,#88bbff);}
.rc-hoenn .rc-bar{background:linear-gradient(90deg,#007744,#44ff99);}
.rc-sinnoh .rc-bar{background:linear-gradient(90deg,#7700cc,#cc88ff);}
.rc-unova .rc-bar{background:linear-gradient(90deg,#222,#888);}
.rc-kalos .rc-bar{background:linear-gradient(90deg,#006699,#44ccff);}
.rc-alola .rc-bar{background:linear-gradient(90deg,#ff7700,#ffcc44);}
.rc-galar .rc-bar{background:linear-gradient(90deg,#7a0026,#e23b6d);}
.rc-paldea .rc-bar{background:linear-gradient(90deg,#6a1bbf,#c77dff);}
.rc-name{font-family:var(--px);font-size:10px;color:var(--gold);margin-bottom:5px;margin-top:4px;}
.rc-info{font-size:11px;color:var(--muted);}
.rc-prog{height:4px;background:rgba(255,255,255,.08);margin-top:10px;border-radius:2px;overflow:hidden;}
.rc-prog-fill{height:100%;background:var(--red);transition:width .4s;border-radius:2px;}
.rc-prog-fill.done{background:var(--green);}
.rc-check{position:absolute;top:12px;right:14px;color:var(--green);font-size:18px;}
.rc-lock{position:absolute;top:12px;right:14px;color:var(--muted);font-size:14px;}
.shop-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.shop-card{background:var(--card);border:1px solid var(--border);padding:13px;text-align:center;cursor:pointer;transition:all .15s;}
.shop-card:hover{border-color:var(--gold);}
.shop-name{font-size:11px;color:var(--text);font-weight:700;margin-bottom:3px;}
.shop-cost{font-size:16px;color:var(--gold);font-weight:800;}
.shop-desc{font-size:9px;color:var(--muted);margin-top:4px;line-height:1.5;}
.shop-qty{font-size:10px;color:var(--dim);margin-top:5px;}
.save-dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--green);margin-right:6px;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:.4;}50%{opacity:1;}}

/* INTRO */
#screen-intro{align-items:center;justify-content:center;min-height:100vh;gap:0;}
.intro-scene{width:100%;max-width:720px;height:360px;position:relative;overflow:hidden;border:2px solid var(--border);}
.intro-bg{position:absolute;inset:0;}
.intro-floor{position:absolute;bottom:0;left:0;right:0;height:90px;border-top:2px solid rgba(60,80,160,.5);}
.intro-flash{position:absolute;inset:0;background:#fff;opacity:0;pointer-events:none;transition:opacity .08s;}
.intro-player{position:absolute;bottom:90px;width:96px;height:96px;image-rendering:pixelated;transition:left 1.4s cubic-bezier(.4,0,.2,1);}
.intro-trainer{position:absolute;bottom:90px;width:96px;height:96px;image-rendering:pixelated;transition:right 1.4s cubic-bezier(.4,0,.2,1);transform:scaleX(-1);}
.intro-vs{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:var(--px);font-size:48px;color:var(--gold);text-shadow:0 0 40px rgba(255,215,0,.7);opacity:0;transition:opacity .35s;}
.intro-vs.show{opacity:1;}
.intro-trainer-info{position:absolute;bottom:96px;right:14px;text-align:right;opacity:0;transition:opacity .4s;}
.intro-trainer-info.show{opacity:1;}
.iti-name{font-family:var(--px);font-size:9px;color:var(--gold);}
.iti-title{font-size:11px;color:var(--text);}
.intro-text{padding:18px;font-size:14px;color:var(--text);letter-spacing:1px;text-align:center;min-height:54px;background:var(--panel);border:1px solid var(--border);border-top:none;max-width:720px;width:100%;}

/* BATTLE ARENA */
#screen-battle{gap:0;}
.battle-arena{position:relative;height:306px;overflow:hidden;border:1px solid var(--border);border-bottom:none;}
.ba-default{background:linear-gradient(180deg,#050d1e 0%,#0d1d3a 45%,#152a50 75%,#0f2040 100%);}
.ba-fire{background:linear-gradient(180deg,#120400 0%,#2d0900 45%,#451200 75%,#380d00 100%);}
.ba-water{background:linear-gradient(180deg,#020818 0%,#050f28 45%,#081838 75%,#051025 100%);}
.ba-ice{background:linear-gradient(180deg,#020c18 0%,#041428 45%,#071e38 75%,#051628 100%);}
.ba-ghost{background:linear-gradient(180deg,#040108 0%,#0c0420 45%,#120630 75%,#0a0420 100%);}
.ba-psychic{background:linear-gradient(180deg,#100320 0%,#200640 45%,#300860 75%,#250650 100%);}
.ba-fighting{background:linear-gradient(180deg,#100405 0%,#220810 45%,#341218 75%,#28090f 100%);}
.ba-dark{background:linear-gradient(180deg,#030305 0%,#08080c 45%,#0e0c14 75%,#0a0910 100%);}
.ba-ground{background:linear-gradient(180deg,#0e0800 0%,#1e1200 45%,#2c1c00 75%,#231600 100%);}
.ba-steel{background:linear-gradient(180deg,#080a10 0%,#101520 45%,#182030 75%,#141828 100%);}
.ba-dragon{background:linear-gradient(180deg,#030818 0%,#070e2e 45%,#0c1440 75%,#091030 100%);}
.ba-bug{background:linear-gradient(180deg,#040800 0%,#0a1500 45%,#101e00 75%,#0c1800 100%);}
.ba-poison{background:linear-gradient(180deg,#0c0010 0%,#160020 45%,#200030 75%,#1a0025 100%);}
.arena-floor{position:absolute;bottom:0;left:0;right:0;height:80px;border-top:1px solid rgba(60,80,160,.3);}
.hp-box{position:absolute;background:rgba(6,9,26,.95);border:1px solid rgba(50,70,160,.6);padding:9px 13px;min-width:210px;}
.hp-box.enemy-box{top:12px;left:12px;}
.hp-box.player-box{bottom:12px;right:12px;}
.hp-row1{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.hp-poke-name{font-size:12px;color:var(--text);font-weight:700;}
.hp-poke-lv{font-size:9px;color:var(--muted);}
.hp-track{height:6px;background:rgba(255,255,255,.08);margin:4px 0 2px;border-radius:3px;overflow:hidden;}
.hp-fill{height:100%;transition:width .5s ease,background .3s;border-radius:3px;}
.hp-nums{font-size:9px;color:var(--muted);text-align:right;}
.status-tag{display:inline-block;font-size:8px;padding:1px 5px;font-weight:800;color:#fff;letter-spacing:.5px;}
.st-BRN{background:#cc5500;}.st-PAR{background:#cccc00;color:#000;}.st-PSN{background:#7700cc;}
.st-SLP{background:#445566;}.st-FRZ{background:#0088cc;}
.poke-sprite-enemy{position:absolute;bottom:104px;left:80px;image-rendering:pixelated;width:120px;height:120px;}
.poke-sprite-player{position:absolute;bottom:20px;right:70px;image-rendering:pixelated;width:120px;height:120px;}
.sp-shake{animation:spShake .35s;}
@keyframes spShake{0%,100%{transform:translateX(0)}25%{transform:translateX(-10px)}75%{transform:translateX(10px)}}
.sp-faint{animation:spFaint .6s forwards;}
@keyframes spFaint{to{transform:translateY(80px);opacity:0}}
.arena-shadow{position:absolute;border-radius:50%;background:radial-gradient(ellipse,rgba(0,0,0,.4) 0%,transparent 70%);}
.shadow-enemy{width:130px;height:18px;bottom:106px;left:50px;}
.shadow-player{width:130px;height:18px;bottom:20px;right:42px;}
.weather-indicator{position:absolute;top:10px;right:10px;font-size:9px;color:var(--dim);background:rgba(0,0,0,.65);padding:3px 10px;border:1px solid var(--border);display:none;}
/* Damage floats */
.dmg-float{position:absolute;font-family:var(--px);font-size:13px;color:#ff5566;pointer-events:none;z-index:20;animation:dfloat .9s ease-out forwards;}
.dmg-float.heal{color:var(--green);}
.dmg-float.miss{color:var(--muted);font-size:11px;}
.dmg-float.super-eff{color:var(--gold);font-size:15px;}
@keyframes dfloat{0%{opacity:1;transform:translateY(0);}100%{opacity:0;transform:translateY(-48px);}}
/* Party dots */
.party-row{display:flex;gap:5px;padding:5px 10px;background:rgba(0,0,0,.5);}
.party-dot{width:18px;height:18px;border-radius:50%;border:2px solid rgba(255,255,255,.15);transition:all .3s;}
.party-dot.active{border-color:var(--gold);box-shadow:0 0 8px rgba(255,215,0,.5);}
.party-dot.fainted{background:#333!important;}

/* BATTLE UI */
.battle-ui{background:var(--panel);border:1px solid var(--border);padding:11px;}
.battle-log{min-height:56px;max-height:72px;overflow-y:auto;font-size:11px;margin-bottom:9px;line-height:1.8;padding:4px 8px;background:rgba(0,0,0,.5);border:1px solid var(--border);}
.ll-damage{color:#ff8866;}.ll-heal{color:#66cc66;}.ll-info{color:var(--muted);}.ll-super{color:#ffcc00;}.ll-resist{color:#7777aa;}
.moves-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:8px;}
.move-btn{background:var(--card);border:1px solid var(--border);color:var(--text);font-family:var(--font);font-size:12px;padding:9px 10px;cursor:pointer;text-align:left;transition:all .1s;display:flex;justify-content:space-between;align-items:center;gap:6px;}
.move-btn:hover:not(:disabled){filter:brightness(1.2);transform:scale(1.01);}
.move-btn:disabled{opacity:.25;cursor:not-allowed;}
.move-left{display:flex;align-items:center;gap:6px;flex:1;min-width:0;}
.move-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.move-name{font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.move-right{display:flex;align-items:center;gap:6px;flex-shrink:0;}
.move-type-mini{font-size:8px;padding:2px 5px;border-radius:2px;text-transform:uppercase;font-weight:800;white-space:nowrap;}
.move-pp{font-size:9px;color:var(--muted);}
.battle-actions{display:flex;gap:6px;align-items:center;}
.party-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin:7px 0;}
.party-btn{background:var(--card);border:1px solid var(--border);color:var(--text);font-family:var(--font);font-size:10px;padding:8px;cursor:pointer;text-align:center;display:flex;flex-direction:column;align-items:center;gap:2px;transition:all .1s;}
.party-btn:hover:not(:disabled){border-color:var(--gold);}
.party-btn:disabled{opacity:.25;cursor:not-allowed;}
.party-btn img{width:52px;height:52px;image-rendering:pixelated;}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,10,.88);z-index:200;align-items:center;justify-content:center;}
.modal-overlay.active{display:flex;}
.modal{background:var(--panel);border:2px solid var(--gold);padding:26px;max-width:500px;width:92%;text-align:center;animation:screenIn .2s ease;}
.modal h2{color:var(--gold);margin-bottom:12px;font-family:var(--px);font-size:14px;}
.modal p{font-size:12px;color:var(--dim);margin-bottom:18px;line-height:1.8;}
.modal-btns{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;}

/* TYPES */
.t-normal{background:#A8A878;}.t-fire{background:#F08030;}.t-water{background:#6890F0;}
.t-electric{background:#F8D030;color:#333;}.t-grass{background:#78C850;}.t-ice{background:#98D8D8;color:#333;}
.t-fighting{background:#C03028;}.t-poison{background:#A040A0;}.t-ground{background:#E0C068;color:#333;}
.t-flying{background:#A890F0;}.t-psychic{background:#F85888;}.t-bug{background:#A8B820;}
.t-rock{background:#B8A038;}.t-ghost{background:#705898;}.t-dragon{background:#7038F8;}
.t-dark{background:#705848;}.t-steel{background:#B8B8D0;color:#333;}.t-fairy{background:#EE99AC;color:#333;}

/* Save toast */
.save-toast{position:fixed;bottom:22px;right:22px;background:var(--panel);border:1px solid var(--gold);color:var(--gold);padding:8px 16px;font-family:var(--px);font-size:8px;z-index:300;animation:toastAnim 2.4s ease forwards;pointer-events:none;}
@keyframes toastAnim{0%{opacity:0;transform:translateY(8px);}15%{opacity:1;transform:translateY(0);}80%{opacity:1;}100%{opacity:0;transform:translateY(-8px);}}

/* ═══ MEJORAS v3: INICIO, BOTÓN HOME Y MENÚS MÁS GRANDES ═══ */
/* Fondo de la pantalla de inicio con inicio.png */
#screen-title{
  background-image:linear-gradient(rgba(4,6,18,.35),rgba(4,6,18,.55)),url('./inicio.png');
  background-size:cover;background-position:center;background-repeat:no-repeat;
  max-width:100%;width:100vw;
}
.title-overlay{position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse at center,rgba(6,9,26,.55) 0%,rgba(6,9,26,.25) 35%,transparent 65%);pointer-events:none;}
.title-content{background:rgba(6,9,26,.45);backdrop-filter:blur(2px);border:1px solid var(--border);border-radius:14px;padding:34px 40px;box-shadow:0 18px 60px rgba(0,0,0,.55);}
.title-main{font-family:var(--px);font-size:clamp(26px,6vw,52px);}
.title-sub-line{font-size:clamp(16px,3.5vw,30px);color:#fff5a0;}
.title-eyebrow{font-size:10px;letter-spacing:6px;color:var(--gold2);}
.title-sub{font-size:14px;max-width:420px;color:#aab8e0;}
.title-regions{font-size:10px;color:#9aa8d0;letter-spacing:1px;max-width:440px;line-height:1.8;}
.title-btns{gap:14px;}
#screen-title .btn-primary{font-size:13px;padding:16px 44px;}
#screen-title .btn-gold{font-size:12px;padding:14px 36px;}

/* Botón HOME (volver al inicio) */
#btn-home{position:fixed;top:14px;left:14px;z-index:150;display:none;
  background:linear-gradient(135deg,#15203f 0%,#0c1430 100%);color:var(--gold2);
  border:1px solid var(--border2);border-radius:10px;font-family:var(--px);font-size:9px;
  letter-spacing:1px;padding:11px 16px;cursor:pointer;transition:all .15s;
  box-shadow:0 4px 16px rgba(0,0,0,.45);}
#btn-home:hover{filter:brightness(1.25);transform:translateY(-1px);border-color:var(--gold);}

/* Menús / paneles más grandes y visuales */
.screen{max-width:1040px;}
.panel{padding:24px;border-radius:14px;box-shadow:0 6px 24px rgba(0,0,0,.3);}
.panel-title{font-size:10px;margin-bottom:18px;padding-bottom:12px;}
.hub-header{padding:18px 24px;border-radius:14px;}
.bp-block .bp-val{font-size:32px;}
.region-card{padding:20px 24px;border-radius:12px;}
.rc-name{font-size:12px;margin-bottom:7px;}
.rc-info{font-size:12px;}
.shop-card{padding:18px;border-radius:12px;}
.shop-name{font-size:13px;}
.shop-cost{font-size:19px;}
.shop-desc{font-size:10px;}
.poke-card{min-height:140px;border-radius:12px;padding:12px;}
.poke-card img{width:84px;height:84px;}
.poke-name{font-size:10px;}

/* Combate más grande */
.battle-arena{height:360px;border-radius:14px 14px 0 0;}
.poke-sprite-enemy{width:150px;height:150px;left:90px;bottom:120px;}
.poke-sprite-player{width:150px;height:150px;right:80px;bottom:22px;}
.shadow-enemy{width:150px;bottom:122px;left:60px;}
.shadow-player{width:150px;bottom:22px;right:50px;}
.hp-box{min-width:240px;padding:12px 16px;border-radius:10px;}
.hp-poke-name{font-size:14px;}
.hp-track{height:8px;}
.battle-ui{padding:16px;border-radius:0 0 14px 14px;}
.battle-log{min-height:70px;max-height:90px;font-size:13px;padding:8px 12px;border-radius:8px;}
.move-btn{font-size:14px;padding:13px 14px;border-radius:9px;}
.moves-grid{gap:8px;}
.battle-actions{gap:8px;}
.btn-secondary{font-size:13px;padding:10px 18px;border-radius:8px;}
.party-btn{font-size:11px;padding:11px;border-radius:9px;}
.party-btn img{width:60px;height:60px;}
.party-dot{width:22px;height:22px;}
.dmg-float{font-size:16px;}
.dmg-float.super-eff{font-size:19px;}

/* Trainer portrait en combate */
.battle-trainer{position:absolute;top:54px;right:16px;width:74px;height:74px;image-rendering:pixelated;
  border:2px solid var(--border2);border-radius:10px;background:rgba(6,9,26,.7);object-fit:cover;
  box-shadow:0 4px 14px rgba(0,0,0,.5);display:none;z-index:5;}

/* Modal más grande */
.modal{padding:32px;border-radius:16px;max-width:560px;}
.modal h2{font-size:16px;}
.modal p{font-size:14px;}

/* Selección de personaje */
#screen-charselect{min-height:100vh;justify-content:center;align-items:center;}
.char-grid{display:flex;gap:24px;justify-content:center;flex-wrap:wrap;margin:10px 0;}
.char-card{background:var(--card);border:2px solid var(--border);border-radius:16px;padding:22px 28px;cursor:pointer;
  transition:all .18s;display:flex;flex-direction:column;align-items:center;gap:12px;min-width:180px;}
.char-card:hover{border-color:var(--gold);transform:translateY(-4px);box-shadow:0 10px 30px rgba(255,215,0,.18);}
.char-card.selected{border-color:var(--gold);box-shadow:0 0 0 2px rgba(255,215,0,.4);}
.char-card img{width:150px;height:150px;object-fit:contain;image-rendering:pixelated;
  filter:drop-shadow(0 6px 14px rgba(0,0,0,.5));}
.char-name{font-family:var(--px);font-size:12px;color:var(--gold2);letter-spacing:2px;}

@media(max-width:680px){
  #screen-title .btn-primary{font-size:11px;padding:13px 30px;}
  .title-content{padding:24px 22px;}
  .poke-sprite-enemy,.poke-sprite-player{width:118px;height:118px;}
}
