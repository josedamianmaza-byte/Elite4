<body>
<canvas id="stars"></canvas>
<button id="btn-home" onclick="goHome()" title="Volver al inicio">🏠 INICIO</button>

<!-- TITLE -->
<div id="screen-title" class="screen active">
  <div class="title-overlay"></div>
  <div class="title-content">
    <div class="title-eyebrow">★ POKÉMON ★</div>
    <div class="title-main">ELITE 4<br><span class="title-sub-line">EL DESAFÍO</span></div>
    <div class="title-sub">Derrota a todos los Altos Mandos de las 9 regiones y conviértete en el mejor entrenador</div>
    <div class="title-btns">
      <button class="btn-primary" onclick="newGame()">▶ NUEVA PARTIDA</button>
      <button class="btn-gold" id="btn-continue" style="display:none" onclick="continueGame()">↩ CONTINUAR</button>
    </div>
    <div class="title-regions">🔴 Kanto · 🌙 Johto · 🌊 Hoenn · 💎 Sinnoh · ⚫ Unova · 🌸 Kalos · 🌺 Alola · ⚔️ Galar · 🟣 Paldea</div>
  </div>
</div>

<!-- CHARSELECT -->
<div id="screen-charselect" class="screen">
  <div class="panel" style="text-align:center;width:100%;">
    <div class="panel-title" style="justify-content:center;">🧢 ELIGE TU PERSONAJE</div>
    <p style="font-size:13px;color:var(--muted);margin-bottom:18px;">Esta será tu skin cuando te enfrentes a los Altos Mandos</p>
    <div class="char-grid">
      <div class="char-card" id="char-boy" onclick="chooseSkin('trainer1.png','Chico')">
        <img src="./trainer1.png" onerror="this.onerror=null;this.src='https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/trainers/red.png';" alt="Chico">
        <div class="char-name">CHICO</div>
      </div>
      <div class="char-card" id="char-girl" onclick="chooseSkin('trainer2.png','Chica')">
        <img src="./trainer2.png" onerror="this.onerror=null;this.src='https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/trainers/leaf.png';" alt="Chica">
        <div class="char-name">CHICA</div>
      </div>
    </div>
    <button class="btn-secondary" onclick="goTo('title')" style="margin-top:18px;">← Volver</button>
  </div>
</div>

<!-- TEAM BUILDER -->
<div id="screen-team" class="screen">
  <div class="panel">
    <div class="panel-title">📋 IMPORTAR EQUIPO — Formato Showdown / Pokepast</div>
    <p style="font-size:11px;color:var(--muted);margin-bottom:8px;">Soporta apodos, IVs, EVs, naturalezas, habilidades y objetos. Sets competitivos recomendados.</p>
    <textarea id="paste-input" placeholder="Garchomp @ Rocky Helmet&#10;Ability: Rough Skin&#10;EVs: 252 Atk / 4 SpD / 252 Spe&#10;Jolly Nature&#10;- Earthquake&#10;- Dragon Claw&#10;- Stealth Rock&#10;- Fire Fang"></textarea>
    <div id="parse-err" class="msg-err" style="display:none;"></div>
    <div id="parse-ok" class="msg-ok" style="display:none;"></div>
    <div style="display:flex;gap:8px;margin-top:9px;flex-wrap:wrap;">
      <button class="btn-primary" onclick="importTeam()">IMPORTAR EQUIPO</button>
      <button class="btn-secondary" onclick="loadExample()">⚡ Equipo de ejemplo</button>
      <button class="btn-secondary" onclick="goTo('title')" style="margin-left:auto;">← Volver</button>
    </div>
  </div>
  <div class="panel">
    <div class="panel-title">⚔ TU EQUIPO</div>
    <div class="team-grid" id="team-grid"></div>
  </div>
  <div style="text-align:center;margin-top:6px;">
    <button class="btn-primary" id="btn-coliseo" style="display:none;" onclick="goHub()">▶ IR AL COLISEO</button>
  </div>
</div>

<!-- HUB -->
<div id="screen-hub" class="screen">
  <div class="hub-header">
    <div class="bp-block"><div class="bp-label">BATTLE POINTS</div><div class="bp-val" id="bp-val">0 BP</div></div>
    <span id="items-val" style="font-size:11px;color:var(--muted);"></span>
    <div style="display:flex;gap:8px;">
      <button class="btn-secondary" onclick="goTo('team')">EQUIPO</button>
      <button class="btn-secondary" onclick="saveGame()" style="color:var(--green);">💾 GUARDAR</button>
    </div>
  </div>
  <div class="panel">
    <div class="panel-title">🛒 TIENDA BP</div>
    <div class="shop-grid">
      <div class="shop-card" onclick="buyItem('revive')">
        <div class="shop-name">REVIVIR</div>
        <div class="shop-cost">10 BP</div>
        <div class="shop-desc">Revive un Pokémon debilitado con 50% HP</div>
        <div class="shop-qty" id="qty-revive"></div>
      </div>
      <div class="shop-card" onclick="buyItem('maxpotion')">
        <div class="shop-name">MAX POCIÓN</div>
        <div class="shop-cost">8 BP</div>
        <div class="shop-desc">Restaura HP completo en combate</div>
        <div class="shop-qty" id="qty-maxpotion"></div>
      </div>
      <div class="shop-card" onclick="buyItem('fullrestore')">
        <div class="shop-name">FULL RESTORE</div>
        <div class="shop-cost">15 BP</div>
        <div class="shop-desc">HP completo y cura estado alterado</div>
        <div class="shop-qty" id="qty-fullrestore"></div>
      </div>
    </div>
  </div>
  <div class="panel">
    <div class="panel-title">🏆 ALTO MANDO — ELIGE TU DESAFÍO</div>
    <div class="hub-grid" id="regions-grid"></div>
  </div>
</div>

<!-- INTRO -->
<div id="screen-intro" class="screen">
  <div class="intro-scene ba-default" id="intro-scene">
    <div class="arena-floor" style="background:rgba(20,30,60,.4);"></div>
    <div class="intro-flash" id="intro-flash"></div>
    <img id="intro-player" class="intro-player" src="" alt="" style="left:-120px;">
    <img id="intro-trainer" class="intro-trainer" src="" alt="" style="right:-120px;">
    <div class="intro-vs" id="intro-vs">VS</div>
    <div class="intro-trainer-info" id="iti">
      <div class="iti-name" id="iti-name"></div>
      <div class="iti-title" id="iti-title"></div>
    </div>
  </div>
  <div class="intro-text" id="intro-text"></div>
</div>

<!-- BATTLE -->
<div id="screen-battle" class="screen">
  <div class="battle-arena ba-default" id="battle-arena">
    <div class="arena-floor" id="arena-floor"></div>
    <div class="arena-shadow shadow-enemy"></div>
    <div class="arena-shadow shadow-player"></div>
    <div class="weather-indicator" id="weather-bar"></div>
    <img id="battle-trainer" class="battle-trainer" src="" alt="">
    <div class="hp-box enemy-box">
      <div class="hp-row1"><span class="hp-poke-name" id="e-name">—</span><span class="hp-poke-lv" id="e-lv">Lv—</span></div>
      <div class="hp-track"><div class="hp-fill" id="e-hp-fill" style="width:100%;background:var(--green)"></div></div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span id="e-status"></span><span class="hp-nums" id="e-hp-nums"></span>
      </div>
    </div>
    <img id="e-sprite" class="poke-sprite-enemy" src="" alt="" style="display:none;">
    <img id="p-sprite" class="poke-sprite-player" src="" alt="" style="display:none;">
    <div class="hp-box player-box">
      <div class="hp-row1"><span class="hp-poke-name" id="p-name">—</span><span class="hp-poke-lv" id="p-lv">Lv—</span></div>
      <div class="hp-track"><div class="hp-fill" id="p-hp-fill" style="width:100%;background:var(--green)"></div></div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span id="p-status"></span><span class="hp-nums" id="p-hp-nums"></span>
      </div>
    </div>
  </div>
  <div class="party-row" id="party-row"></div>
  <div class="battle-ui">
    <div class="battle-log" id="battle-log"></div>
    <div id="moves-ui">
      <div class="moves-grid" id="moves-grid"></div>
      <div class="battle-actions">
        <button class="btn-secondary" id="btn-switch" onclick="openSwitch()">CAMBIAR</button>
        <button class="btn-secondary" id="btn-item" onclick="openItems()">MOCHILA</button>
        <button class="btn-secondary" onclick="confirmFlee()" style="margin-left:auto;color:#ff5566;">RENDIRSE</button>
      </div>
    </div>
    <div id="switch-ui" style="display:none;">
      <div style="font-size:10px;color:var(--muted);margin-bottom:6px;font-family:var(--px);">ELIGE TU POKÉMON:</div>
      <div class="party-grid" id="party-grid"></div>
      <button class="btn-secondary" onclick="closeSwitch()" style="margin-top:7px;" id="btn-cancel-switch">CANCELAR</button>
    </div>
  </div>
</div>

<!-- MODAL -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal">
    <h2 id="modal-title"></h2>
    <p id="modal-body"></p>
    <div class="modal-btns" id="modal-btns"></div>
  </div>
</div>

